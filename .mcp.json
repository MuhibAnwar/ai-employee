{
  "mcpServers": {
    "email": {
      "command": "node",
      "args": ["/workspaces/ai-employee/mcp-servers/email-mcp/index.js"],
      "env": {
        "GMAIL_TOKEN_PATH": "/workspaces/ai-employee/secrets/gmail_token.json",
        "DRY_RUN": "false"
      }
    },
    "odoo": {
      "command": "node",
      "args": ["/workspaces/ai-employee/mcp-servers/odoo-mcp/index.js"],
      "env": {
        "ODOO_URL": "http://localhost:8069",
        "ODOO_DB": "odoo",
        "ODOO_USERNAME": "admin",
        "ODOO_PASSWORD": "admin"
      }
    }
  }
}
