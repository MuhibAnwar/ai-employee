# AI Employee — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── General ──────────────────────────────────────────
# Path to your Obsidian vault (absolute or relative to project root)
VAULT_PATH=./vault

# Set to "true" to log actions without executing external calls
DRY_RUN=true

# ── Gmail Watcher (Silver Tier) ───────────────────────
# GMAIL_CLIENT_ID=your_client_id_here
# GMAIL_CLIENT_SECRET=your_client_secret_here
# GMAIL_TOKEN_PATH=./secrets/gmail_token.json
# GMAIL_CREDENTIALS_PATH=./secrets/gmail_credentials.json

# ── LinkedIn Watcher (Silver Tier) ────────────────────
# Uses linkedin-api library (pip install linkedin-api) — no browser required
# LINKEDIN_USERNAME=your_linkedin_email@example.com
# LINKEDIN_PASSWORD=your_linkedin_password

# ── LinkedIn OAuth 2.0 Posting ────────────────────────
# Required for scripts/post_to_linkedin.py OAuth path (w_member_social scope)
# Get token: https://www.linkedin.com/developers/apps → OAuth 2.0 tools → Generate token
# LINKEDIN_ACCESS_TOKEN=your_oauth_access_token_here

# ── Email MCP Server (Silver Tier) ────────────────────
# Port the email MCP server listens on
# EMAIL_MCP_PORT=3001

# ── Facebook Watcher (Gold Tier) ──────────────────────
# Uses requests + session cookies saved from Playwright (one-time capture)
# Capture: python -m playwright open --save-storage=secrets/facebook_storage.json https://www.facebook.com
# FACEBOOK_SESSION_PATH=./secrets/facebook_storage.json

# ── Instagram Watcher (Gold Tier) ─────────────────────
# Uses instagrapi library (pip install instagrapi) — no browser required
# Create session: from instagrapi import Client; cl=Client(); cl.login(u,p); cl.dump_settings('secrets/instagram_session.json')
# INSTAGRAM_SESSION_PATH=./secrets/instagram_session.json

# ── Twitter/X Watcher (Gold Tier) ─────────────────────
# Uses tweepy library (pip install tweepy) — no browser required
# Get credentials from https://developer.twitter.com/
# TWITTER_API_KEY=your_api_key
# TWITTER_API_SECRET=your_api_secret
# TWITTER_ACCESS_TOKEN=your_access_token
# TWITTER_ACCESS_SECRET=your_access_token_secret

# ── Banking / Finance (Gold Tier) ─────────────────────
# BANK_API_TOKEN=your_bank_api_token
# BANK_API_BASE_URL=https://api.yourbank.com/v1

# ── Odoo Community ERP (Gold Tier) ────────────────────
# Install Odoo Community: https://www.odoo.com/page/download
# Or run via Docker: see mcp-servers/odoo-mcp/README.md
# ODOO_URL=http://localhost:8069
# ODOO_DB=odoo
# ODOO_USERNAME=admin
# ODOO_PASSWORD=admin

# ── Claude Code API ───────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key
